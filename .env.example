# Copy this file to `.env` for local development.
# Never put real secrets in `.env.example`.

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Guesty
GUESTY_API_KEY=your_guesty_api_key
GUESTY_BASE_URL=https://open-api.guesty.com/v1
# JSON map keyed by cabin IDs used in app.
GUESTY_LISTING_ID_MAP={"cime-02":"guesty_listing_id_1","station-perchee":"guesty_listing_id_2"}

# Optional: GitHub API access for local scripts/tools.
GITHUB_TOKEN=your_github_token_here
